{
  "manifest_version": 3,
  "name": "FYJOB — AI Job Match Scanner",
  "version": "1.0.0",
  "description": "Scan any job posting with brutal FAANG-level AI analysis. Know your real match score before you apply.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "sidePanel",
    "scripting"
  ],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://*.indeed.com/*",
    "https://*.jobstreet.co.id/*",
    "https://*.jobstreet.com/*",
    "https://*.jobsdb.com/*",
    "https://*.kalibrr.com/*",
    "https://*.glints.com/*",
    "https://*.karir.com/*",
    "https://*.glassdoor.com/*",
    "https://*.monster.com/*",
    "https://*.ziprecruiter.com/*",
    "https://*.simplyhired.com/*",
    "https://*.dice.com/*",
    "https://*.wellfound.com/*",
    "https://*.builtin.com/*",
    "https://*.jobs.lever.co/*",
    "https://*.lever.co/*",
    "https://*.greenhouse.io/*",
    "https://*.boards.greenhouse.io/*",
    "https://*.ashbyhq.com/*",
    "https://*.smartrecruiters.com/*",
    "https://*.workable.com/*",
    "https://*.myworkdayjobs.com/*",
    "https://*.workday.com/*",
    "https://*.jobvite.com/*",
    "https://*.icims.com/*",
    "https://*.taleo.net/*",
    "https://*.recruitee.com/*",
    "https://*.join.com/*",
    "https://*.azurewebsites.net/*",
    "https://fyjob.my.id/*",
    "https://www.fyjob.my.id/*",
    "https://*.vercel.app/*",
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*",
    "http://localhost:5173/*",
    "http://127.0.0.1:5173/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Open FYJOB Scanner"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "sidebar_action": {
    "default_panel": "sidepanel.html",
    "default_title": "FYJOB Scanner",
    "default_icon": "icons/icon16.png"
  },
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "fypodku@otaruram.dev",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "websiteContent",
          "browsingActivity",
          "authenticationInfo"
        ]
      }
    },
    "gecko_android": {
      "strict_min_version": "128.0",
      "data_collection_permissions": {
        "required": [
          "websiteContent",
          "browsingActivity",
          "authenticationInfo"
        ]
      }
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.linkedin.com/*",
        "https://*.indeed.com/*",
        "https://*.jobstreet.co.id/*",
        "https://*.jobstreet.com/*",
        "https://*.jobsdb.com/*",
        "https://*.kalibrr.com/*",
        "https://*.glints.com/*",
        "https://*.karir.com/*",
        "https://*.glassdoor.com/*",
        "https://*.monster.com/*",
        "https://*.ziprecruiter.com/*",
        "https://*.simplyhired.com/*",
        "https://*.dice.com/*",
        "https://*.wellfound.com/*",
        "https://*.builtin.com/*",
        "https://*.jobs.lever.co/*",
        "https://*.lever.co/*",
        "https://*.greenhouse.io/*",
        "https://*.boards.greenhouse.io/*",
        "https://*.ashbyhq.com/*",
        "https://*.smartrecruiters.com/*",
        "https://*.workable.com/*",
        "https://*.myworkdayjobs.com/*",
        "https://*.workday.com/*",
        "https://*.jobvite.com/*",
        "https://*.icims.com/*",
        "https://*.taleo.net/*",
        "https://*.recruitee.com/*",
        "https://*.join.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://fyjob.my.id/*",
        "https://www.fyjob.my.id/*",
        "https://*.vercel.app/*",
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*",
        "http://localhost:5173/*",
        "http://127.0.0.1:5173/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}