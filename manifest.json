{
  "manifest_version": 3,
  "name": "FYJOB Scanner",
  "version": "1.1.0",
  "description": "Quick job match analysis with synced FYJOB auth.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting",
    "sidePanel",
    "windows"
  ],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://*.indeed.com/*",
    "https://*.jobstreet.co.id/*",
    "https://*.jobstreet.com/*",
    "https://*.jobsdb.com/*",
    "https://*.kalibrr.com/*",
    "https://*.glints.com/*",
    "https://*.karir.com/*",
    "https://*.glassdoor.com/*",
    "https://*.monster.com/*",
    "https://*.ziprecruiter.com/*",
    "https://*.simplyhired.com/*",
    "https://*.dice.com/*",
    "https://*.wellfound.com/*",
    "https://*.builtin.com/*",
    "https://*.jobs.lever.co/*",
    "https://*.lever.co/*",
    "https://*.greenhouse.io/*",
    "https://*.boards.greenhouse.io/*",
    "https://*.ashbyhq.com/*",
    "https://*.smartrecruiters.com/*",
    "https://*.workable.com/*",
    "https://*.myworkdayjobs.com/*",
    "https://*.workday.com/*",
    "https://*.jobvite.com/*",
    "https://*.icims.com/*",
    "https://*.taleo.net/*",
    "https://*.recruitee.com/*",
    "https://*.join.com/*",
    "https://fyjob.my.id/*",
    "https://www.fyjob.my.id/*",
    "https://*.fyjob.my.id/*",
    "https://*.azurewebsites.net/*",
    "https://*.vercel.app/*",
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*",
    "http://localhost:5173/*",
    "http://127.0.0.1:5173/*"
  ],
  "action": {
    "default_title": "Open FYJOB Scanner",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "sidebar_action": {
    "default_panel": "sidepanel.html",
    "default_title": "FYJOB Scanner",
    "default_icon": "icons/icon16.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.linkedin.com/*",
        "https://*.indeed.com/*",
        "https://*.jobstreet.co.id/*",
        "https://*.jobstreet.com/*",
        "https://*.jobsdb.com/*",
        "https://*.kalibrr.com/*",
        "https://*.glints.com/*",
        "https://*.karir.com/*",
        "https://*.glassdoor.com/*",
        "https://*.monster.com/*",
        "https://*.ziprecruiter.com/*",
        "https://*.simplyhired.com/*",
        "https://*.dice.com/*",
        "https://*.wellfound.com/*",
        "https://*.builtin.com/*",
        "https://*.jobs.lever.co/*",
        "https://*.lever.co/*",
        "https://*.greenhouse.io/*",
        "https://*.boards.greenhouse.io/*",
        "https://*.ashbyhq.com/*",
        "https://*.smartrecruiters.com/*",
        "https://*.workable.com/*",
        "https://*.myworkdayjobs.com/*",
        "https://*.workday.com/*",
        "https://*.jobvite.com/*",
        "https://*.icims.com/*",
        "https://*.taleo.net/*",
        "https://*.recruitee.com/*",
        "https://*.join.com/*",
        "https://fyjob.my.id/*",
        "https://www.fyjob.my.id/*",
        "https://*.fyjob.my.id/*",
        "https://*.azurewebsites.net/*",
        "https://*.vercel.app/*",
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*",
        "http://localhost:5173/*",
        "http://127.0.0.1:5173/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*.png"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "fypodku@otaruram.dev",
      "strict_min_version": "140.0"
    }
  }
}
